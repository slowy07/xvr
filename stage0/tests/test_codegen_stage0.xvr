include std;
include lexer;
include parser;
include codegen;

proc test_codegen_basic() {
    std::println("=== Test: Basic Codegen ===");
    initLexer("var x = 42");
    initParser();
    initCodegen();
    
    generate();
    var ir = getIR();
    
    std::println("Generated IR length: {}", len(ir));
    std::println("PASS: codegen_basic");
}

proc test_codegen_function() {
    std::println("=== Test: Function Codegen ===");
    initCodegen();
    
    var fn = generateFunction("main", "  ret i32 0");
    std::println("Generated function: {}", len(fn));
    std::println("PASS: codegen_function");
}

proc test_codegen_if() {
    std::println("=== Test: If Codegen ===");
    initCodegen();
    
    var if_ir = generateIf("%cond", "  br label %end", "");
    std::println("Generated if: {}", len(if_ir));
    std::println("PASS: codegen_if");
}

proc test_codegen_while() {
    std::println("=== Test: While Codegen ===");
    initCodegen();
    
    var while_ir = generateWhile("%cond", "  br label %cond");
    std::println("Generated while: {}", len(while_ir));
    std::println("PASS: codegen_while");
}

proc main() {
    std::println("Stage0 Codegen Tests\n");
    
    test_codegen_basic();
    test_codegen_function();
    test_codegen_if();
    test_codegen_while();
    
    std::println("\n=== All Codegen Tests Passed ===");
}

main();