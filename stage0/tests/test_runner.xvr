proc main() {
    std::println("Stage0 Bootstrap Compiler Tests");
    std::println("Note: Running with stage0 compiler, not main xvr");
    std::println("");
    std::println("Tests will validate:");
    std::println("  - Token types work");
    std::println("  - Keywords recognized");
