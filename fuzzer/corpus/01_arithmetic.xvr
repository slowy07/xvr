include std;

var a = 10;
var b = 3;
std::print("a = {}, b = {}\n", a, b);
std::print("a + b = {}\n", a + b);
std::print("a - b = {}\n", a - b);
std::print("a * b = {}\n", a * b);
std::print("a / b = {}\n", a / b);
std::print("a % b = {}\n", a % b);
std::print("a == b = {}\n", a == b);
std::print("a != b = {}\n", a != b);
std::print("a > b = {}\n", a > b);
std::print("a < b = {}\n", a < b);
std::print("a >= b = {}\n", a >= b);
std::print("a <= b = {}\n", a <= b);