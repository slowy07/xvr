include std;

var a = 10;
var b = 20;
if (a < b) {
    std::print("a is less than b\n");
}

if (a == b) {
    std::print("equal\n");
} else {
    std::print("not equal\n");
}

var score = 85;
if (score >= 90) {
    std::print("A\n");
} else if (score >= 80) {
    std::print("B\n");
} else if (score >= 70) {
    std::print("C\n");
} else {
    std::print("F\n");
}