include std;

std::print("=== Print Support ===\n");

std::print("arfy slowy\n");
std::print("xaviera " + "putri\n");

std::print("\tDerune\nCitizen\n");

std::print("Integer: {}\n", 42);
std::print("Float: {}\n", 3.14);

std::print("Boolean true: {}\n", true);
std::print("Boolean false: {}\n", false);

std::print("Null: {}\n", null);
