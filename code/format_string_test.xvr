include std;

std::print("=== Format String Test ===\n");

var name = "world";
std::print("Hello, {}!\n", name);

var num = 42;
std::print("The answer is {}\n", num);

var pi = 3.14;
std::print("Pi is {}\n", pi);

var first = "John";
var last = "Doe";
std::print("Name: {} {}\n", first, last);

std::print("Multiple: {} + {} = {}\n", 1, 2, 3);

var arr = [1, 2, 3];
std::print("Array: ");
std::print(arr);
std::print("\n");
