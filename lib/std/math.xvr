# round(float32): float32 - Returns x rounded to nearest integer (32-bit)
proc math_round_f32(x: float32): float32
    return 0.0


# round(float64): float64 - Returns x rounded to nearest integer (64-bit)
proc math_round_f64(x: float64): float64
    return 0.0


