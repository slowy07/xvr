# floor(float32): float32 - Returns the largest integer not greater than x (32-bit)
proc math_floor_f32(x: float32): float32
    return 0.0


# floor(float64): float64 - Returns the largest integer not greater than x (64-bit)
proc math_floor_f64(x: float64): float64
    return 0.0


