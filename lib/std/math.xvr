# exp(float32): float32 - Returns e raised to the power of x (32-bit)
proc math_exp_f32(x: float32): float32
    return 0.0


# exp(float64): float64 - Returns e raised to the power of x (64-bit)
proc math_exp_f64(x: float64): float64
