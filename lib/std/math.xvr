# ceil(float32): float32 - Returns the smallest integer not less than x (32-bit)
proc math_ceil_f32(x: float32): float32
    return 0.0


# ceil(float64): float64 - Returns the smallest integer not less than x (64-bit)
proc math_ceil_f64(x: float64): float64
    return 0.0


